# Copy to .env and edit. These are the integration-cluster credentials — deliberately
# DIFFERENT from the production ParadeDB in server-backend (PG_USER/PG_PASS there).

# Superuser (used internally by pg_replica's control plane).
SU_PASSWORD=pgr_super_pw

# Streaming-replication role (pg_basebackup, walreceiver, pg_rewind, LSN probe).
REPL_PASSWORD=pgr_repl_pw

# Application role + database the integration tests / your app connect with.
APP_USER=weido
APP_PASSWORD=weido_test_pw
APP_DB=weido

# Quorum-synchronous replication: on = zero committed-transaction loss on failover.
SYNCHRONOUS=on
